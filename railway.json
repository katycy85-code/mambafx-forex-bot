{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "node server/index.js",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "variables": {
    "TRADOVATE_USERNAME": "",
    "TRADOVATE_PASSWORD": "",
    "TRADOVATE_CID": "",
    "TRADOVATE_SECRET": "",
    "TRADOVATE_DEVICE_ID": "",
    "TRADOVATE_API_URL": "https://demo.tradovateapi.com"
  }
}
}
