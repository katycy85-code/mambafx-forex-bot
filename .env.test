# Test Mode Configuration
NODE_ENV=test
TEST_MODE=true

# MT4 Credentials
MT4_SERVER=OANDA-v20 Live-1
MT4_LOGIN=4005436
MT4_PASSWORD=test_mode

# SMS Notifications (Test Mode - logs to console)
TWILIO_ACCOUNT_SID=test_account_sid
TWILIO_AUTH_TOKEN=test_auth_token
TWILIO_PHONE_NUMBER=+1234567890
USER_PHONE_NUMBER=917-972-1327

# Bot Configuration
BOT_MODE=manual
CAPITAL=100
LEVERAGE=50
MAX_POSITION_SIZE=25
MAX_RISK_PER_TRADE=1

# Trading Hours (NY Open)
TRADING_START_HOUR=6
TRADING_START_MINUTE=30
TRADING_END_HOUR=15
TRADING_END_MINUTE=0

# Instruments
PRIMARY_INSTRUMENT=EUR/USD
SECONDARY_INSTRUMENT=GBP/USD
TERTIARY_INSTRUMENT=AUD/USD

# Server
PORT=3000
HOST=localhost

# Database
DATABASE_URL=sqlite:///test_trades.db

# Test Mode Settings
LOG_TRADES_TO_CONSOLE=true
SIMULATE_TRADES=true
SKIP_REAL_ORDERS=true
